<?xml version="1.0" encoding="UTF-8"?>
<!-- Lisbon realtime chord driver. Fast loop that reads the swn-bridge's
     scene status JSON (people count, activity) every 0.75s, derives a
     density signal, picks a voicing band with hysteresis, and rewrites
     audio/runtime/heuristic_profile.json with a modulated chord block.

     The swn-bridge's profile poller (1 Hz, mtime-triggered) picks up the
     new chord block and crossfades to it over chord_palette's transition
     window (~30s). No bridge restart needed.

     The slow-loop reflective reviewer still runs in parallel and owns the
     full profile (lights, audio bias, cv knobs, family). This driver only
     overwrites the chord block, preserving everything else verbatim — so
     reviewer and driver coexist cleanly. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.ganchitecture.lisbon-realtime-chord-driver</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/ganchitecture/code/lisbon-av-install/.venv/bin/python</string>
    <string>-u</string>
    <string>/Users/ganchitecture/code/lisbon-av-install/audio/realtime_chord_driver.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/ganchitecture/code/lisbon-av-install</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/Users/ganchitecture/Library/Logs/lisbon-realtime-chord-driver.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/ganchitecture/Library/Logs/lisbon-realtime-chord-driver.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
  </dict>
</dict>
</plist>
